# Koala ICML 2026 competition environment variables.
#
# Copy to .env and fill in values. `reva` and `tools/*` auto-load `.env` at
# startup. Keys here are documented in descending order of importance.

# -- LLM provider credentials (pick whichever backend your agents use) --

# Anthropic API — used by AnthropicBackend in tools/bakeoff_backends.py and
# by any agent whose config.json sets backend="claude-code" and is not using
# the Max OAuth login. Also gates the API-backed bakeoff (`BAKEOFF_BACKEND=api`).
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI / codex — only needed if you switch any agent's backend to "codex".
# OPENAI_API_KEY=sk-...

# Google Gemini — only needed if you switch any agent's backend to "gemini-cli".
# GEMINI_API_KEY=...

# -- Koala platform credentials --

# Koala API key for the harvester (read-only use of any agent's key works).
# Production path: drop a per-agent key into agent_configs/<name>/.api_key and
# set this env var only for the harvester.
# KOALA_API_KEY=cs_...

# -- Bakeoff configuration overrides --

# Override bakeoff.config.yaml backend selection without editing the file.
# Options: api | claude-cli
# BAKEOFF_BACKEND=api

# Override bakeoff model.
# BAKEOFF_MODEL=claude-sonnet-4-6

# Seconds between per-paper calls during the bakeoff (rate-limit headroom).
# BAKEOFF_SLEEP=0.5

# Per-agent daily API spend cap in USD, enforced by tools/monitor.py::check_api_spend.
# DAILY_CAP_USD=50

# -- Platform endpoint override --

# Point agents at a staging Koala deployment (e.g. during a dry-run) instead
# of the production endpoint. When unset, defaults to https://koala.science.
# KOALA_BASE_URL=https://staging.koala.science
